#!/usr/bin/env python3
"""skill-review — checks each skill under skills/*:

1. Every permission declared in permissions.yml OR SKILL.md frontmatter
   (SETUP §5.3.5) is cited (by literal name) *with an explanation* — a
   fenced code block, or a prose/list line with at least 5 other words —
   in the skill's SKILL.md body (why + where, not a bare declaration).
2. Phase headings (## Phase N) are numbered contiguously from 0.
3. Phase 0 is present.

Stdlib only, no network, no third-party imports.

# ponytail: "explained" is a word-count heuristic (fenced block, or a line
# with >=5 other words), not real NLP. It's enough to reject a bare
# "Permissions used: X, Y" list without over-engineering a prose parser.
"""
import os
import re
import sys

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
SKILLS_DIR = os.path.join(ROOT, "skills")

PERMISSION_LINE = re.compile(r"^-\s*permission:\s*(.+)$")
PHASE_HEADING = re.compile(r"^#+\s*Phase\s+(\d+)\b")
FRONTMATTER_PERM_KEY = re.compile(r"^permissions:\s*$")
FRONTMATTER_PERM_ITEM = re.compile(r"^\s*-\s*(?:permission:\s*)?(.+)$")


def parse_permissions(path):
    permissions = []
    with open(path, encoding="utf-8") as f:
        for line in f:
            match = PERMISSION_LINE.match(line.strip())
            if match:
                permissions.append(match.group(1).strip())
    return permissions


def parse_frontmatter_permissions(skill_md_text):
    """Parse a `permissions:` list declared in SKILL.md frontmatter — the
    other declaration location SETUP §5.3.5 names alongside permissions.yml
    (WR-02)."""
    frontmatter = get_frontmatter(skill_md_text)
    permissions = []
    collecting = False
    for line in frontmatter.splitlines():
        if FRONTMATTER_PERM_KEY.match(line.strip()):
            collecting = True
            continue
        if collecting:
            item = FRONTMATTER_PERM_ITEM.match(line)
            if item:
                permissions.append(item.group(1).strip())
                continue
            if line.strip() == "":
                continue
            collecting = False
    return permissions


def parse_phase_numbers(skill_md_text):
    numbers = []
    for line in skill_md_text.splitlines():
        match = PHASE_HEADING.match(line.strip())
        if match:
            numbers.append(int(match.group(1)))
    return numbers


def cited_with_explanation(body, permission):
    """True if `permission` appears inside a fenced code block, or on a
    prose/list line alongside >=5 other words — not just a bare
    declaration line like "Permissions used: X, Y" (WR-01)."""
    in_fence = False
    for line in body.splitlines():
        if line.strip().startswith("```"):
            in_fence = not in_fence
            continue
        if permission not in line:
            continue
        if in_fence:
            return True
        other_words = [w for w in line.split() if permission not in w]
        if len(other_words) >= 5:
            return True
    return False


def get_frontmatter(text):
    """Return the --- delimited frontmatter block's contents, or "" if
    there isn't one."""
    parts = text.split("---", 2)
    if text.startswith("---") and len(parts) >= 3:
        return parts[1]
    return ""


def strip_frontmatter(text):
    """Return the body of SKILL.md, with the --- frontmatter block removed,
    so permission citations are checked against the body, not restated in
    frontmatter."""
    parts = text.split("---", 2)
    if text.startswith("---") and len(parts) >= 3:
        return parts[2]
    return text


def main():
    if not os.path.isdir(SKILLS_DIR):
        print("skill-review: no skills/ directory found.")
        return 0

    violations = []
    skill_names = sorted(
        n for n in os.listdir(SKILLS_DIR) if os.path.isdir(os.path.join(SKILLS_DIR, n))
    )

    for name in skill_names:
        skill_dir = os.path.join(SKILLS_DIR, name)
        skill_md_path = os.path.join(skill_dir, "SKILL.md")
        permissions_path = os.path.join(skill_dir, "permissions.yml")

        if not os.path.isfile(skill_md_path):
            violations.append(f"skill-review: {name}: missing SKILL.md")
            continue

        with open(skill_md_path, encoding="utf-8") as f:
            skill_md_text = f.read()
        body = strip_frontmatter(skill_md_text)

        declared = []
        if os.path.isfile(permissions_path):
            declared += [(p, "permissions.yml") for p in parse_permissions(permissions_path)]
        declared += [
            (p, "SKILL.md frontmatter") for p in parse_frontmatter_permissions(skill_md_text)
        ]

        for permission, source in declared:
            if permission not in body:
                violations.append(
                    f"skill-review: {name}: permission {permission!r} declared "
                    f"in {source} but not cited in SKILL.md body"
                )
            elif not cited_with_explanation(body, permission):
                violations.append(
                    f"skill-review: {name}: permission {permission!r} cited but "
                    f"not explained — needs a why/where sentence or code fence, "
                    f"not a bare mention (SETUP §5.3.5)"
                )

        raw_numbers = parse_phase_numbers(skill_md_text)
        seen = set()
        dupes = {n for n in raw_numbers if n in seen or seen.add(n)}
        if dupes:
            violations.append(
                f"skill-review: {name}: duplicate phase number(s) {sorted(dupes)}"
            )

        phase_numbers = sorted(set(raw_numbers))
        if not phase_numbers:
            violations.append(f"skill-review: {name}: no Phase headings found")
        else:
            if phase_numbers[0] != 0:
                violations.append(f"skill-review: {name}: Phase 0 is missing")
            expected = list(range(phase_numbers[0], phase_numbers[-1] + 1))
            if phase_numbers != expected:
                violations.append(
                    f"skill-review: {name}: phase numbers {phase_numbers} are not "
                    f"contiguous (expected {expected})"
                )

    if violations:
        for v in violations:
            print(v)
        print(f"skill-review: FAIL ({len(violations)} violation(s))")
        return 1

    print("skill-review: OK — permissions cited, phases contiguous from 0")
    return 0


if __name__ == "__main__":
    sys.exit(main())
