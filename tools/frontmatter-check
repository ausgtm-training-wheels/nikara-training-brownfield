#!/usr/bin/env python3
"""frontmatter-check — loads each skill's SKILL.md and verifies its
frontmatter (the block between the two `---` lines) parses and contains a
non-empty `description:` field (D-09). Stdlib only, no network.
"""
import os
import sys

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
SKILLS_DIR = os.path.join(ROOT, "skills")


def frontmatter_parses(skill_md_path):
    with open(skill_md_path, encoding="utf-8") as f:
        text = f.read()
    parts = text.split("---", 2)
    if not text.startswith("---") or len(parts) < 3:
        return False
    frontmatter = parts[1]
    return "description:" in frontmatter and bool(
        [line for line in frontmatter.splitlines() if line.startswith("description:") and line.strip() != "description:"]
    )


def main():
    if not os.path.isdir(SKILLS_DIR):
        print("frontmatter-check: no skills/ directory found.")
        return 0

    names = sorted(n for n in os.listdir(SKILLS_DIR) if os.path.isdir(os.path.join(SKILLS_DIR, n)))
    failed = []
    for name in names:
        skill_md = os.path.join(SKILLS_DIR, name, "SKILL.md")
        if not os.path.isfile(skill_md) or not frontmatter_parses(skill_md):
            failed.append(name)

    if failed:
        print(f"frontmatter-check: FAIL — could not parse frontmatter for: {', '.join(failed)}")
        return 1

    print(f"frontmatter-check: OK — {len(names)} skill(s) parsed")
    return 0


if __name__ == "__main__":
    sys.exit(main())
